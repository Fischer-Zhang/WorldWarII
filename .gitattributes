* text=auto

# Project text files should stay LF so Bash scripts and Godot text resources
# behave the same on Windows, macOS and Linux.
*.gd text eol=lf
*.gd.uid text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.godot text eol=lf
*.cfg text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.svg text eol=lf

# Binary assets and packaged exports.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ogg binary
*.wav binary
*.mp3 binary
*.zip binary
*.tar.gz binary
*.exe binary
*.x86_64 binary
*.pck binary
